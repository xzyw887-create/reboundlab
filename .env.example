# === Application ===
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# === Database (PostgreSQL + TimescaleDB) ===
DATABASE_URL=postgresql://reboundlab:reboundlab@localhost:5432/reboundlab
DATABASE_POOL_SIZE=10

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth ===
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === Market Data ===
BINANCE_API_URL=https://fapi.binance.com
BYBIT_API_URL=https://api.bybit.com
MARKET_DATA_SYNC_INTERVAL_MS=60000
MARKET_DATA_MIN_HISTORY_DAYS=365

# === Backtester ===
BACKTESTER_MAX_CONCURRENT_JOBS=4
BACKTESTER_JOB_TIMEOUT_MS=300000

# === Payments (Phase 3) ===
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# === Email (Phase 3) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# === Monitoring ===
SENTRY_DSN=
