# Production web: Next.js + Python backtester
FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json turbo.json ./
COPY apps/web/package.json apps/web/
COPY backtester/requirements.txt backtester/

RUN npm ci --include-workspace-root

RUN pip3 install --no-cache-dir -r backtester/requirements.txt --break-system-packages

COPY . .

ENV NODE_ENV=production
ENV PORT=3000
ENV PROJECT_ROOT=/app
ENV HOSTNAME=0.0.0.0

RUN npm run web:build

EXPOSE 3000

CMD ["npm", "run", "start", "--workspace=@reboundlab/web", "--", "-H", "0.0.0.0"]
